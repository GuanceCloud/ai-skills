{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "charts/dashboard-schema.json",
  "type": "object",
  "title": "DashboardData",
  "description": "Schema description.",
  "additionalProperties": true,
  "properties": {
    "title": {
      "type": "string",
      "description": "Schema description."
    },
    "main": {
      "type": "object",
      "description": "Schema description.",
      "properties": {
        "vars": {
          "$ref": "common/common-vars-schema.json"
        },
        "charts": {
          "type": "array",
          "description": "Schema description.",
          "items": {
            "$ref": "chart-schema.json"
          }
        },
        "groups": {
          "type": "array",
          "description": "Schema description.",
          "items": {
            "type": "object",
            "properties": {
              "name": {
                "type": "string",
                "description": "Schema description."
              },
              "extend": {
                "type": "object",
                "description": "Schema description.",
                "properties": {
                  "bgColor": {
                    "type": "string",
                    "description": "Schema description."
                  }
                }
              }
            }
          }
        },
        "type": {
          "description": "Schema description.",
          "anyOf": [
            {
              "type": "string",
              "const": "template"
            },
            {
              "type": "null"
            }
          ]
        }
      }
    },
    "dashboardExtend": {
      "description": "Schema description.",
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "groupUnfoldStatus": {
          "type": "object",
          "description": "Schema description.",
          "additionalProperties": {
            "type": "boolean",
            "description": "Schema description."
          }
        }
      }
    }
  }
}
