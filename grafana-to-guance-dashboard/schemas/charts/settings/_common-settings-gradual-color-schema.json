{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "charts/settings/_common-settings-gradual-color-schema.json",
  "title": "CommonGradualColorSettings",
  "description": "Schema description.",
  "type": "object",
  "properties": {
    "gradualColor": {
      "description": "Schema description.",
      "type": "object",
      "required": [
        "type",
        "colorKey",
        "levelCount"
      ],
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "auto",
            "custom"
          ],
          "description": "Schema description."
        },
        "colorKey": {
          "type": "string",
          "description": "Schema description.",
          "enum": [
            "interpolateYlOrBr",
            "interpolateBuPu",
            "interpolatePuBu",
            "interpolateBuGn"
          ]
        },
        "minVal": {
          "description": "Schema description.",
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ]
        },
        "maxVal": {
          "description": "Schema description.",
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ]
        },
        "levelCount": {
          "type": "integer",
          "description": "Schema description."
        },
        "levels": {
          "type": "array",
          "description": "Schema description.",
          "items": {
            "type": "object",
            "required": [
              "color"
            ],
            "properties": {
              "min": {
                "description": "Schema description."
              },
              "max": {
                "description": "Schema description."
              },
              "color": {
                "description": "Schema description."
              }
            }
          }
        }
      },
      "additionalProperties": false
    }
  }
}
