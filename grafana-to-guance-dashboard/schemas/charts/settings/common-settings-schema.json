{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "charts/settings/common-settings-schema.json",
  "title": "CommonChartSettings",
  "type": "object",
  "description": "Schema description.",
  "allOf": [
    {
      "properties": {
        "showTitle": {
          "type": "boolean",
          "description": "Schema description.",
          "default": true
        },
        "titleDesc": {
          "type": "string",
          "description": "Schema description.",
          "default": ""
        },
        "isSampling": {
          "type": "boolean",
          "description": "Schema description.",
          "default": true
        },
        "changeWorkspace": {
          "type": "boolean",
          "description": "Schema description.",
          "default": false
        },
        "workspaceUUID": {
          "type": "string",
          "examples": [
            "wksp_xxxx1,wksp_xxxx2"
          ],
          "description": "Schema description."
        },
        "workspaceName": {
          "type": "array",
          "description": "Schema description.",
          "items": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ]
          }
        },
        "showFieldMapping": {
          "type": "boolean",
          "description": "Schema description.",
          "default": false
        },
        "openThousandsSeparator": {
          "type": "boolean",
          "default": true,
          "description": "Schema description."
        },
        "precision": {
          "type": "string",
          "default": "2",
          "description": "Schema description."
        },
        "openTimeOffset": {
          "type": "boolean",
          "description": "Schema description.",
          "default": false
        },
        "aliasVersion": {
          "type": "integer",
          "description": "Alias version marker, fixed to 2",
          "const": 2
        }
      }
    },
    {
      "$ref": "settings-time-schema.json"
    }
  ]
}
