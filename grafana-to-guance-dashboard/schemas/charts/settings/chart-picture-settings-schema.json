{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "charts/settings/chart-picture-settings-schema.json",
  "title": "ChartPictureSettings",
  "description": "Schema description.",
  "type": "object",
  "additionalProperties": true,
  "properties": {
    "showTitle": {
      "type": "boolean",
      "description": "Schema description.",
      "default": true
    },
    "titleDesc": {
      "type": "string",
      "description": "Schema description.",
      "default": ""
    },
    "url": {
      "type": "string",
      "description": "Schema description."
    },
    "backgroundStyle": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "backgroundSize": {
          "description": "Schema description.",
          "type": "string",
          "enum": [
            "fill",
            "contain",
            "cover"
          ]
        },
        "backgroundPosition": {
          "description": "Schema description.",
          "type": "string",
          "enum": [
            "center"
          ]
        }
      }
    }
  }
}
