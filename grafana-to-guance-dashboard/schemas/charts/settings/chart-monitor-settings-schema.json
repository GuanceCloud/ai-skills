{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "$id": "charts/settings/chart-monitor-settings-schema.json",
    "title": "ChartMonitorSettings",
    "description": "监控器图表配置信息",
    "type": "object",
    "additionalProperties": true,
    "allOf": [
        {
            "$ref": "common-settings-schema.json"
        },
        {
            "properties": {
                "isTimeInterval": {
                    "type": "boolean",
                    "description": "是否开启时间分片",
                    "default": false
                },
                "showPart": {
                    "type": "string",
                    "description": "监控器图显示模式，可选配置分别为全部、仅统计图、仅列表",
                    "enum": [
                        "all",
                        "statistic",
                        "list"
                    ]
                },
                "pageSize": {
                    "description": "列表每页显示的最大记录数量",
                    "type": "integer",
                    "default": 50,
                    "enum": [
                        10,
                        20,
                        50,
                        100
                    ]
                },
                "inColumns": {
                    "type": "array",
                    "description": "默认固定显示的列",
                    "items": {
                        "type": "object",
                        "properties": {
                            "field": {
                                "type": "string"
                            },
                            "headerName": {
                                "type": "string"
                            },
                            "hide": {
                                "type": "boolean"
                            }
                        }
                    }
                },
                "addColumns": {
                    "type": "array",
                    "description": "添加显示列",
                    "items": {
                        "type": "object",
                        "properties": {
                            "field": {
                                "type": "string"
                            },
                            "headerName": {
                                "type": "string"
                            },
                            "hide": {
                                "type": "boolean"
                            }
                        }
                    }
                }
            }
        },
        {
            "$ref": "settings-units-schema.json"
        }
    ]
}
