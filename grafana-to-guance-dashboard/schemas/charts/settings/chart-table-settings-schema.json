{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "charts/settings/chart-table-settings-schema.json",
  "title": "ChartTableSettings",
  "description": "Schema description.",
  "type": "object",
  "additionalProperties": true,
  "allOf": [
    {
      "$ref": "common-settings-schema.json"
    },
    {
      "properties": {
        "alias": {
          "$ref": "settings-alias-schema.json"
        },
        "colors": {
          "$ref": "settings-colors-schema.json"
        },
        "levels": {
          "$ref": "settings-levels-schema.json"
        },
        "isTimeInterval": {
          "type": "boolean",
          "description": "Schema description.",
          "default": false
        },
        "queryMode": {
          "type": "string",
          "description": "Schema description.",
          "enum": [
            "toGroupColumn",
            "toOneColumn"
          ]
        },
        "showColumns": {
          "type": "array",
          "description": "Schema description.",
          "items": {
            "type": "string",
            "examples": [
              "avg(load5s)"
            ]
          }
        },
        "valMappings": {
          "type": "array",
          "description": "Schema description.",
          "items": {
            "type": "object",
            "properties": {
              "field": {
                "type": "string",
                "description": "Schema description."
              },
              "originalVal": {
                "type": "array",
                "description": "",
                "items": {
                  "anyOf": [
                    {
                      "type": "string"
                    },
                    {
                      "type": "integer"
                    }
                  ]
                }
              },
              "mappingVal": {
                "description": "Schema description.",
                "anyOf": [
                  {
                    "type": "string"
                  },
                  {
                    "type": "integer"
                  }
                ]
              },
              "operation": {
                "description": "Schema description.",
                "enum": [
                  ">",
                  ">=",
                  "<",
                  "<=",
                  "=",
                  "!=",
                  "between",
                  "=~",
                  "!=~",
                  "nodata"
                ]
              }
            }
          }
        },
        "valColorMappings": {
          "type": "array",
          "description": "Schema description.",
          "items": {
            "type": "object",
            "required": [
              "field",
              "value",
              "bgColor",
              "operation",
              "fontColor"
            ],
            "properties": {
              "field": {
                "type": "string",
                "description": "Schema description."
              },
              "value": {
                "type": "array",
                "description": "",
                "items": {
                  "anyOf": [
                    {
                      "type": "string"
                    },
                    {
                      "type": "integer"
                    }
                  ]
                }
              },
              "bgColor": {
                "type": "string",
                "description": "Schema description."
              },
              "fontColor": {
                "type": "string",
                "description": "Schema description."
              },
              "operation": {
                "description": "Schema description.",
                "enum": [
                  ">",
                  ">=",
                  "<",
                  "<=",
                  "=",
                  "!=",
                  "between",
                  "=~",
                  "!=~",
                  "nodata"
                ]
              }
            }
          }
        },
        "mainMeasurementQueryCode": {
          "type": "string",
          "description": "Schema description.",
          "default": "A"
        },
        "mainMeasurementSort": {
          "type": "string",
          "enum": [
            "top",
            "bottom"
          ],
          "description": "Schema description."
        },
        "mainMeasurementLimit": {
          "type": "integer",
          "description": "Schema description."
        },
        "disableFuncList": {
          "type": "boolean",
          "description": "Schema description.",
          "readOnly": true
        }
      }
    },
    {
      "$ref": "settings-units-schema.json"
    }
  ]
}
