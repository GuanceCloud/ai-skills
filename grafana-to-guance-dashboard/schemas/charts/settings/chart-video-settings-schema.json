{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "$id": "charts/settings/chart-video-settings-schema.json",
    "title": "ChartVideoSettings",
    "description": "视频图表配置信息",
    "type": "object",
    "additionalProperties": true,
    "allOf": [
        {
            "$ref": "common-settings-schema.json"
        },
        {
            "properties": {
                "volume": {
                    "type": "integer",
                    "description": "当前音量"
                },
                "minVolume": {
                    "type": "integer",
                    "description": "最小音量"
                },
                "maxVolume": {
                    "type": "integer",
                    "description": "最大音量"
                },
                "autoplay": {
                    "type": "boolean",
                    "description": "是否自动播放"
                },
                "repeatPlay": {
                    "type": "boolean",
                    "description": "是否循环播放"
                },
                "isTimeInterval": {
                    "type": "boolean",
                    "description": "是否开启时间分片",
                    "default": false
                }
            }
        },
        {
            "$ref": "settings-units-schema.json"
        }
    ]
}
