{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "charts/settings/chart-video-settings-schema.json",
  "title": "ChartVideoSettings",
  "description": "Schema description.",
  "type": "object",
  "additionalProperties": true,
  "allOf": [
    {
      "$ref": "common-settings-schema.json"
    },
    {
      "properties": {
        "volume": {
          "type": "integer",
          "description": "Schema description."
        },
        "minVolume": {
          "type": "integer",
          "description": "Schema description."
        },
        "maxVolume": {
          "type": "integer",
          "description": "Schema description."
        },
        "autoplay": {
          "type": "boolean",
          "description": "Schema description."
        },
        "repeatPlay": {
          "type": "boolean",
          "description": "Schema description."
        },
        "isTimeInterval": {
          "type": "boolean",
          "description": "Schema description.",
          "default": false
        }
      }
    },
    {
      "$ref": "settings-units-schema.json"
    }
  ]
