{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "charts/settings/chart-toplist-settings-schema.json",
  "title": "ChartToplistSettings",
  "description": "Schema description.",
  "type": "object",
  "additionalProperties": true,
  "allOf": [
    {
      "$ref": "common-settings-schema.json"
    },
    {
      "properties": {
        "alias": {
          "$ref": "settings-alias-schema.json"
        },
        "colors": {
          "$ref": "settings-colors-schema.json"
        },
        "levels": {
          "$ref": "settings-levels-schema.json"
        },
        "chartType": {
          "type": "string",
          "const": "bar",
          "description": "Schema description."
        },
        "colorMappings": {
          "type": "array",
          "description": "Schema description.",
          "items": {
            "type": "object",
            "required": [
              "value",
              "bgColor",
              "operation"
            ],
            "properties": {
              "value": {
                "type": "array",
                "description": "",
                "items": {
                  "anyOf": [
                    {
                      "type": "string"
                    },
                    {
                      "type": "integer"
                    }
                  ]
                }
              },
              "bgColor": {
                "type": "string",
                "description": "Schema description."
              },
              "operation": {
                "description": "Schema description.",
                "enum": [
                  ">",
                  ">=",
                  "<",
                  "<=",
                  "=",
                  "!=",
                  "between",
                  "=~",
                  "!=~",
                  "nodata"
                ]
              }
            }
          }
        },
        "isTimeInterval": {
          "type": "boolean",
          "description": "Schema description.",
          "default": false
        },
        "mainMeasurementQueryCode": {
          "type": "string",
          "description": "Schema description.",
          "const": "A"
        },
        "mainMeasurementSort": {
          "type": "string",
          "enum": [
            "top",
            "bottom"
          ],
          "description": "Schema description."
        },
        "mainMeasurementLimit": {
          "type": "integer",
          "description": "Schema description."
        },
        "bar": {
          "description": "Schema description.",
          "type": "object",
          "properties": {
            "direction": {
              "type": "string",
              "const": "horizontal"
            },
            "xAxisShowType": {
              "type": "string",
              "const": "groupBy"
            }
          }
        }
      }
    },
    {
      "$ref": "settings-units-schema.json"
    }
  ]
}
