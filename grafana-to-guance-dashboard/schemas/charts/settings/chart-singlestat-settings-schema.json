{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "charts/settings/chart-singlestat-settings-schema.json",
  "title": "ChartSinglestatSettings",
  "description": "Schema description.",
  "type": "object",
  "additionalProperties": true,
  "allOf": [
    {
      "$ref": "common-settings-schema.json"
    },
    {
      "properties": {
        "alias": {
          "$ref": "settings-alias-schema.json"
        },
        "colors": {
          "$ref": "settings-colors-schema.json"
        },
        "levels": {
          "type": "array",
          "description": "Schema description.",
          "items": {
            "type": "object",
            "required": [
              "value",
              "bgColor",
              "operation",
              "fontColor"
            ],
            "properties": {
              "value": {
                "type": "array",
                "description": "",
                "items": {
                  "anyOf": [
                    {
                      "type": "string"
                    },
                    {
                      "type": "integer"
                    }
                  ]
                }
              },
              "bgColor": {
                "type": "string",
                "description": "Schema description."
              },
              "fontColor": {
                "type": "string",
                "description": "Schema description."
              },
              "operation": {
                "description": "Schema description.",
                "enum": [
                  ">",
                  ">=",
                  "<",
                  "<=",
                  "=",
                  "!=",
                  "between",
                  "=~",
                  "!=~",
                  "nodata"
                ]
              }
            }
          }
        },
        "mappings": {
          "type": "array",
          "description": "Schema description.",
          "items": {
            "type": "object",
            "properties": {
              "originalVal": {
                "type": "array",
                "description": "",
                "items": {
                  "anyOf": [
                    {
                      "type": "string"
                    },
                    {
                      "type": "integer"
                    }
                  ]
                }
              },
              "operation": {
                "description": "Schema description.",
                "enum": [
                  ">",
                  ">=",
                  "<",
                  "<=",
                  "=",
                  "!=",
                  "between",
                  "=~",
                  "!=~",
                  "nodata"
                ]
              },
              "mappingVal": {
                "description": "Schema description.",
                "anyOf": [
                  {
                    "type": "string"
                  },
                  {
                    "type": "integer"
                  }
                ]
              }
            }
          }
        },
        "showLine": {
          "$ref": "_common-settings-show-line-schema.json"
        },
        "isTimeInterval": {
          "type": "boolean",
          "description": "Schema description.",
          "default": false
        },
        "xAxisShowType": {
          "type": "string",
          "description": "Schema description.",
          "const": "time"
        },
        "fontColor": {
          "type": "string",
          "description": "Schema description."
        },
        "bgColor": {
          "type": "string",
          "description": "Schema description."
        },
        "sequenceChartType": {
          "description": "Schema description.",
          "enum": [
            "line",
            "bar"
          ]
        },
        "showLineAxis": {
          "type": "boolean",
          "description": "Schema description.",
          "default": false
        }
      }
    },
    {
      "$ref": "settings-units-schema.json"
    },
    {
      "$ref": "settings-compare-schema.json"
    }
  ]
}
