{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "charts/settings/chart-topology-settings-schema.json",
  "title": "ChartTopologySettings",
  "description": "Schema description.",
  "type": "object",
  "additionalProperties": true,
  "properties": {
    "showTitle": {
      "type": "boolean",
      "description": "Schema description.",
      "default": true
    },
    "titleDesc": {
      "type": "string",
      "description": "Schema description.",
      "default": ""
    },
    "showLegend": {
      "type": "string",
      "description": "Schema description.",
      "enum": [
        "none",
        "bottom"
      ]
    },
    "fixedTime": {
      "$ref": "settings-fixed-time-schema.json"
    },
    "color": {
      "type": "object",
      "description": "Schema description.",
      "properties": {
        "key": {
          "type": "string",
          "description": "Schema description.",
          "enum": [
            "color-first",
            "color-second",
            "color-third"
          ]
        },
        "min": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ]
        },
        "max": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ]
        }
      }
    }
  }
}
