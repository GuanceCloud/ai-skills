{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "charts/settings/settings-units-schema.json",
  "title": "ChartUnitsSettings",
  "description": "Schema description.",
  "type": "object",
  "properties": {
    "unitType": {
      "type": "string",
      "description": "Schema description.",
      "enum": [
        "global",
        "custom"
      ]
    },
    "globalUnit": {
      "description": "Schema description.",
      "$ref": "settings-unit-items-schema.json"
    },
    "units": {
      "type": "array",
      "description": "Schema description.",
      "items": {
        "type": "object",
        "required": [
          "name",
          "key",
          "unit"
        ],
        "properties": {
          "name": {
            "type": "string",
            "description": "Schema description.",
            "examples": [
              "avg(load5s)"
            ]
          },
          "key": {
            "type": "string",
            "description": "Schema description.",
            "examples": [
              "avg(load5s)"
            ]
          },
          "unit": {
            "type": "string",
            "description": "Schema description."
          },
          "units": {
            "$ref": "settings-unit-items-schema.json"
          }
        }
      }
    }
  }
}
