{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "charts/settings/chart-chinamap-settings-schema.json",
  "title": "ChartChinaMapSettings",
  "description": "Schema description.",
  "type": "object",
  "additionalProperties": true,
  "allOf": [
    {
      "$ref": "common-settings-schema.json"
    },
    {
      "properties": {
        "alias": {
          "$ref": "settings-alias-schema.json"
        },
        "colors": {
          "$ref": "settings-colors-schema.json"
        },
        "levels": {
          "$ref": "settings-levels-schema.json"
        },
        "isTimeInterval": {
          "type": "boolean",
          "description": "Schema description.",
          "default": false
        },
        "rangeColorKey": {
          "type": "string",
          "description": "Schema description.",
          "enum": [
            "light-blue",
            "blue",
            "light-red",
            "dark-red",
            "dark-yellow",
            "dark-green",
            "dark-blue",
            "dark-purple",
            "light-yellow",
            "light-purple",
            "light-green"
          ]
        },
        "levelArr": {
          "type": "array",
          "description": "Schema description.",
          "items": {
            "type": "object",
            "required": [
              "min",
              "max",
              "color"
            ],
            "properties": {
              "min": {
                "type": "integer",
                "description": "Schema description."
              },
              "max": {
                "type": "integer",
                "description": "Schema description."
              },
              "color": {
                "type": "string",
                "description": "Schema description."
              },
              "isAuto": {
                "type": "boolean",
                "description": "Schema description."
              }
            }
          }
        },
        "showLegend": {
          "type": "string",
          "description": "Schema description.",
          "enum": [
            "none",
            "bottom"
          ]
        },
        "showTopList": {
          "type": "boolean",
          "description": "Schema description.",
          "default": false
        },
        "mainMeasurementQueryCode": {
          "type": "string",
          "description": "Schema description.",
          "default": "A"
        },
        "provinceKey": {
          "type": "string",
          "description": "Schema description."
        }
      }
    },
    {
      "$ref": "settings-units-schema.json"
    }
  ]
}
