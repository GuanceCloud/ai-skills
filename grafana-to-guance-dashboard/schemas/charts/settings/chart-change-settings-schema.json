{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "charts/settings/chart-change-settings-schema.json",
  "title": "ChartChangeSettings",
  "description": "Schema description.",
  "type": "object",
  "additionalProperties": true,
  "allOf": [
    {
      "$ref": "common-settings-schema.json"
    },
    {
      "properties": {
        "alias": {
          "$ref": "settings-alias-schema.json"
        },
        "colors": {
          "$ref": "settings-colors-schema.json"
        },
        "levels": {
          "$ref": "settings-levels-schema.json"
        },
        "calcType": {
          "type": "string",
          "enum": [
            "absolute",
            "relative"
          ],
          "description": "Schema description."
        },
        "queryCodes": {
          "type": "array",
          "description": "Schema description.",
          "items": {
            "type": "string"
          }
        },
        "colorScheme": {
          "type": "integer",
          "description": "Schema description."
        },
        "legendPosition": {
          "type": "string",
          "enum": [
            "left",
            "right",
            "top",
            "bottom",
            "none"
          ],
          "description": "Schema description."
        },
        "legendIncludeBaseValue": {
          "type": "boolean",
          "description": "Schema description."
        },
        "isTimeInterval": {
          "type": "boolean",
          "description": "Schema description.",
          "default": false
        }
      }
    },
    {
      "$ref": "settings-units-schema.json"
    }
  ]
}
