{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "charts/settings/settings-compare-schema.json",
  "title": "ChartCompare",
  "description": "Schema description.",
  "type": "object",
  "properties": {
    "compareChartType": {
      "$ref": "../common/common-chart-types-schema.json"
    },
    "openCompare": {
      "type": "boolean",
      "default": false,
      "description": "Schema description."
    },
    "compareType": {
      "description": "Schema description.",
      "anyOf": [
        {
          "type": "string",
          "const": ""
        },
        {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "hourCompare",
              "dayCompare",
              "weekCompare",
              "monthCompare",
              "circleCompare"
            ]
          }
        }
      ]
    },
    "compares": {
      "type": "array",
      "description": "Schema description.",
      "items": {
        "type": "object",
        "required": [
          "label",
          "value"
        ],
        "properties": {
          "label": {
            "type": "string",
            "description": "Schema description."
          },
          "value": {
            "type": "string",
            "enum": [
              "hourCompare",
              "dayCompare",
              "weekCompare",
              "monthCompare",
              "circleCompare"
            ]
          }
        }
      }
    }
  }
}
