{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "charts/settings/chart-bar-settings-schema.json",
  "title": "ChartBarSettings",
  "description": "Bar chart configuration information",
  "type": "object",
  "additionalProperties": true,
  "allOf": [
    {
      "$ref": "common-settings-schema.json"
    },
    {
      "properties": {
        "direction": {
          "type": "string",
          "default": "vertical",
          "description": "Bar chart display orientation: horizontal or vertical",
          "enum": [
            "vertical",
            "horizontal"
          ]
        },
        "alias": {
          "$ref": "settings-alias-schema.json"
        },
        "colors": {
          "$ref": "settings-colors-schema.json"
        },
        "levels": {
          "$ref": "settings-levels-schema.json"
        },
        "stackType": {
          "$ref": "_common-settings-stack-type-schema.json"
        },
        "stackContent": {
          "$ref": "_common-settings-stack-content-schema.json"
        },
        "openStack": {
          "type": "boolean",
          "description": "Whether stacking mode is enabled",
          "default": false
        },
        "showTopSize": {
          "type": "boolean",
          "const": false,
          "description": "Whether this is a ranking chart; fixed to false for bar charts"
        },
        "aliasVersion": {
          "type": "integer",
          "description": "Alias version marker, fixed to 2",
          "const": 2
        },
        "isTimeInterval": {
          "type": "boolean",
          "description": "Whether time slicing is enabled; fixed enabled for time-series charts",
          "default": false
        },
        "xAxisShowType": {
          "type": "string",
          "description": "X-axis display type; bar charts always display groups",
          "const": "groupBy"
        }
      }
    },
    {
      "$ref": "settings-units-schema.json"
    }
  ]
}
