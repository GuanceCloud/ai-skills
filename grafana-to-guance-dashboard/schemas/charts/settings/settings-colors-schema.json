{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "charts/settings/settings-colors-schema.json",
  "title": "ChartColorsSettings",
  "description": "Schema description.",
  "type": "array",
  "items": {
    "type": "object",
    "required": [
      "color",
      "key",
      "name"
    ],
    "properties": {
      "color": {
        "type": "string",
        "description": "Schema description.",
        "examples": [
          "#dddddd",
          "rgba(10,10,10,30)"
        ]
      },
      "name": {
        "type": "string",
        "description": "Schema description.",
        "examples": [
          "avg(load5s)"
        ]
      },
      "key": {
        "type": "string",
        "description": "Schema description.",
        "examples": [
          "avg(load5s)"
        ]
      }
    },
    "examples": [
      {
        "color": "#dddddd",
        "key": "avg(load5s)",
        "name": "avg(load5s)"
      }
    ]
  }
}
