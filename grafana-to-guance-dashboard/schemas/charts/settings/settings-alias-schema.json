{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "charts/settings/settings-alias-schema.json",
  "title": "ChartAliasSettings",
  "description": "Schema description.",
  "type": "array",
  "items": {
    "type": "object",
    "required": [
      "alias",
      "key",
      "name"
    ],
    "properties": {
      "alias": {
        "type": "string",
        "description": "Schema description.",
        "examples": [
          "{{tags}}",
          "{{host}}",
          "test"
        ]
      },
      "name": {
        "type": "string",
        "description": "Schema description.",
        "examples": [
          "avg(load5s)"
        ]
      },
      "key": {
        "type": "string",
        "description": "Schema description.",
        "examples": [
          "avg(load5s)"
        ]
      },
      "queryCode": {
        "type": "string",
        "description": "Schema description.",
        "examples": [
          "A"
        ]
      }
    },
    "examples": [
      {
        "alias": "{{tags}}",
        "key": "avg(load5s)",
        "name": "avg(load5s)"
      },
      {
        "alias": "Busy System",
        "key": "promql_1",
        "name": "promql_1",
        "queryCode": "A"
      }
    ]
  }
}
