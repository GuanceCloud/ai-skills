{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "charts/settings/settings-fixed-time-schema.json",
  "description": "Schema description.",
  "default": "",
  "anyOf": [
    {
      "type": "string",
      "examples": [
        "15m"
      ]
    },
    {
      "type": "object",
      "required": [
        "key",
        "originKey",
        "startTime",
        "endTime",
        "text"
      ],
      "properties": {
        "key": {
          "type": "string",
          "const": "range"
        },
        "originKey": {
          "type": "string",
          "const": "range"
        },
        "startTime": {
          "type": "integer",
          "description": "Schema description."
        },
        "endTime": {
          "type": "integer",
          "description": "Schema description."
        },
        "text": {
          "type": "string",
          "description": "Schema description.",
          "examples": [
            "2024/09/09 00:00:00 ~ 2024/09/09 16:25:33"
          ]
        }
      }
    }
  ]
}
