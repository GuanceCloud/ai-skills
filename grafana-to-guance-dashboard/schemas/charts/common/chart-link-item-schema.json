{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "charts/common/chart-link-item-schema.json",
  "type": "object",
  "description": "Schema description.",
  "required": [
    "url",
    "open",
    "show",
    "type",
    "showChanged"
  ],
  "properties": {
    "url": {
      "type": "string",
      "description": "Schema description."
    },
    "open": {
      "type": "string",
      "description": "Schema description.",
      "enum": [
        "newWin",
        "curWin",
        "drawerWin"
      ]
    },
    "show": {
      "type": "boolean",
      "description": "Schema description."
    },
    "type": {
      "type": "string",
      "description": "Schema description.",
      "enum": [
        "logging",
        "container",
        "processes",
        "tracing",
        "host",
        "custom"
      ]
    },
    "showChanged": {
      "type": "boolean",
      "description": "Schema description."
    }
  }
}
